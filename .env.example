# PostgreSQL — Render provides this automatically when you link a database.
# Locally it should use the psycopg2 driver prefix.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/urlshortener

# Redis — Render provides a rediss:// (TLS) URL when you link a Redis service.
REDIS_URL=redis://localhost:6379/0

# Cache TTL for redirect payloads (capped by link expiry when set)
CACHE_TTL_SECONDS=3600

# Public origin returned in POST /shorten responses.
# On Render set this to your service URL, e.g. https://url-shortener-xxxx.onrender.com
SHORT_URL_BASE=http://localhost:8000

# Retries if a short_code insert hits a unique constraint (rare)
MAX_SHORTEN_ATTEMPTS=5
